# ── Convex ─────────────────────────────────────
# Required for local development
CONVEX_DEPLOYMENT=dev:your-deployment-id
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-id.convex.cloud

# ── AI Provider Fallbacks ──────────────────────
# Used only when a signed-in user has not stored their own keys in Settings.
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional / Planned Integrations ────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=motionkit-assets
R2_PUBLIC_URL=
