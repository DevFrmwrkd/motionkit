# ─── MotionKit — environment template ─────────────────────────────────
#
# Copy to .env.local (root) and app/.env.local. Fill in your own values.
# NEVER commit real secrets. `.env*.local` is git-ignored; `.env.example`
# (this file) is the shared template.
#
# Most agent-facing keys live on the Convex deployment (set via
# `npx convex env set NAME VALUE --prod` or on the dashboard). The values
# below document what the code expects, not where it should live. See
# the comment on each block for the correct home.

# ─── Convex ───────────────────────────────────────────────────────────
# Lives in: root .env.local (pnpm dev needs it to start the Convex client)
# and in app/.env.local under the NEXT_PUBLIC_ prefix so the browser can
# reach the deployment.
CONVEX_DEPLOYMENT=dev:your-deployment-slug
CONVEX_URL=https://your-deployment-slug.convex.cloud
CONVEX_SITE_URL=https://your-deployment-slug.convex.site
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud

# ─── Convex Auth ──────────────────────────────────────────────────────
# Lives in: Convex deployment env. Generated by `npx @convex-dev/auth`
# on first setup — do not hand-author.
# JWT_PRIVATE_KEY=...
# JWKS=...
# SITE_URL=https://your-app-domain (or http://localhost:3000 in dev)

# ─── Demo mode (optional) ─────────────────────────────────────────────
# Lives in: Convex deployment env. When "true", unauthenticated visitors
# can browse /workstation as the shared demo user. MUST be "false" in
# production unless you truly want a public sandbox — the demo account
# bypasses auth checks by design.
# ENABLE_DEMO_MODE=false

# ─── AI providers (BYOK) ──────────────────────────────────────────────
# Lives in: Convex deployment env. Per-user BYOK keys are stored
# encrypted in the users table; these are optional platform-fallback
# keys used when a user has not supplied their own.
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# Straico is the ONE exception to BYOK — it powers the free 5/day
# anonymous Gemini-3-Flash tier consumed by convex/aiGenerationStraico.ts.
# Rate-limited per-user / per-guest so the platform wallet can't be drained.
# STRAICO_API_KEY=

# ─── Encryption (BYOK at rest) ────────────────────────────────────────
# Lives in: Convex deployment env. 32-byte base64 key used by
# convex/lib/keyStorage.ts to encrypt/decrypt per-user API keys before
# they hit the database. Rotate by re-encrypting the `users` table with
# a new key — the storage format is prefixed with a version so rotation
# is possible without a global downtime.
# ENCRYPTION_KEY=

# ─── Cloudflare R2 — preset bundles + rendered MP4s ───────────────────
# Lives in: Convex deployment env (used by actions) + any deploy target
# that signs uploads client-side.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=motionkit-renders
# R2_PUBLIC_URL=https://renders.your-domain.tld

# ─── R2 uploader (Cloudflare Worker) ──────────────────────────────────
# Lives in: Convex deployment env. Convex actions sign their PUTs with
# this secret; the Worker rejects unsigned uploads.
# R2_UPLOAD_URL=https://uploader.your-domain.tld
# R2_UPLOAD_SECRET=

# ─── Remotion Lambda (one of two render backends) ─────────────────────
# Lives in: Convex deployment env. Used only when RENDER_WORKER_URL is
# unset — otherwise the self-hosted worker is preferred.
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=
# REMOTION_AWS_REGION=us-east-1
# REMOTION_FUNCTION_NAME=
# REMOTION_SERVE_URL=

# ─── Self-hosted render worker (preferred render backend) ─────────────
# Lives in: Convex deployment env.
# If RENDER_WORKER_URL is set, the platform dispatches renders to the
# self-hosted Hetzner/Fastify worker at render-worker/ instead of Lambda.
# See docs/RENDER-PIPELINE.md.
# RENDER_WORKER_URL=https://worker.your-domain.tld
# RENDER_WORKER_SECRET=

# ─── Preset bundle signing (WS-1) ─────────────────────────────────────
# Lives in: Convex deployment env AND local dev shell when running
# scripts/sign-bundle.mjs. Must be the same value or signed bundles will
# fail verification at load time.
# BUNDLE_SIGNING_SECRET=

# ─── Stripe (billing — optional until monetization ships) ─────────────
# Lives in: Convex deployment env. Webhook secret is separate from the
# API keys — get it from the Stripe dashboard when you install the
# webhook endpoint at <CONVEX_SITE_URL>/stripe/webhook.
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
