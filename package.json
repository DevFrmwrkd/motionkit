{
  "name": "motionkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter app dev\" \"npx convex dev\"",
    "dev:app": "pnpm --filter app dev",
    "dev:convex": "npx convex dev",
    "build": "npx convex codegen && pnpm --filter app build",
    "build:worker": "pnpm --filter app build:worker",
    "preview:worker": "pnpm --filter app preview:worker",
    "deploy:worker": "pnpm --filter app deploy:worker",
    "deploy": "npx convex deploy && pnpm build",
    "preset:build": "tsx scripts/build-preset.ts",
    "preset:upload": "tsx scripts/upload-preset.ts",
    "lint": "pnpm --filter app lint",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91",
    "@google/generative-ai": "^0.24.1",
    "@remotion/lambda": "^4.0.447",
    "convex": "^1.21.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
