# Render worker configuration
PORT=4000
HOST=0.0.0.0

# Concurrency — max parallel renders. Keep ≤ (vCPU count - 1) for best throughput.
MAX_CONCURRENCY=2

# HMAC shared secret with the Convex action. Generate with: openssl rand -hex 32
RENDER_WORKER_SECRET=change-me-please-use-openssl-rand

# Directory where finished MP4s are written. Caddy serves this as static files.
OUTPUT_DIR=/var/www/renders

# Public URL base where renders are served (no trailing slash).
# Locally: http://localhost:4000/renders
# Prod:    https://render.yourdomain.com/renders
PUBLIC_URL=http://localhost:4000/renders

# Path to the Remotion entry file (relative to render-worker/).
REMOTION_ENTRY=../app/src/remotion/index.ts

# Chromium executable path (leave empty to let Remotion auto-download).
# On Debian/Ubuntu: /usr/bin/chromium or /usr/bin/google-chrome-stable
CHROMIUM_PATH=
