{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build:sandbox && next dev",
    "build": "pnpm build:sandbox && next build --webpack",
    "build:sandbox": "node ./scripts/build-sandbox.mjs",
    "clean:worker": "find . -path './.git' -prune -o -path './node_modules' -prune -o -name '._*' -type f -delete && rm -rf .next .open-next",
    "build:worker": "pnpm clean:worker && pnpm build:sandbox && bash ./scripts/build-worker.sh",
    "preview:worker": "pnpm clean:worker && pnpm build:sandbox && bash ./scripts/build-worker.sh && wrangler dev",
    "deploy:worker": "pnpm clean:worker && pnpm build:sandbox && bash ./scripts/build-worker.sh && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@auth/core": "^0.37.4",
    "@base-ui/react": "^1.3.0",
    "@convex-dev/auth": "^0.0.91",
    "@google/generative-ai": "^0.24.1",
    "@remotion/cli": "^4.0.0",
    "@remotion/lambda": "^4.0.447",
    "@remotion/player": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.21.0",
    "d3-geo": "^3.1.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.500.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.4",
    "remotion": "^4.0.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.1",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
